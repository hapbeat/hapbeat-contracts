{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hapbeat.com/schemas/kit-manifest.schema.json",
  "title": "Hapbeat Kit Manifest",
  "description": "Hapbeat Kit の manifest.json を検証するための JSON Schema。Kit は触覚コンテンツの配布単位であり、wav クリップと Event ID の対応表を含む。",
  "type": "object",
  "required": ["schema_version", "version", "name", "events"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "manifest スキーマのバージョン。2.0.0 で `events` の役割を command-mode 専用に narrow 化し、stream-mode を `stream_events` bucket に分離した (DEC-031)。",
      "examples": ["2.0.0"]
    },
    "version": {
      "type": "string",
      "description": "Kit 自体のバージョン（semver 形式）",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(-(0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(\\.(0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*)?$",
      "examples": ["1.0.0", "0.1.0-alpha"]
    },
    "name": {
      "type": "string",
      "description": "Kit の名前（= Kit 一意識別子 = ディレクトリ名 = wire-protocol 上の kit_id）。英小文字・数字・ハイフンのみ。先頭は英小文字。",
      "pattern": "^[a-z][a-z0-9-]*$",
      "examples": ["basic-impacts", "vr-environment-v2"]
    },
    "description": {
      "type": "string",
      "description": "Kit の説明文"
    },
    "author": {
      "type": "string",
      "description": "Kit の作者名"
    },
    "created_at": {
      "type": "string",
      "description": "Kit の作成日時（ISO 8601 形式）",
      "format": "date-time",
      "examples": ["2025-01-15T10:30:00Z"]
    },
    "target_device": {
      "type": "object",
      "description": "対象デバイス情報。Kit 作者がチューニング時に使ったハードウェア / 設定のコンテキストを記録する。再生時の互換チェックや再現性確認に利用する。",
      "required": ["firmware_version_min"],
      "additionalProperties": false,
      "properties": {
        "firmware_version_min": {
          "type": "string",
          "description": "対応する最小ファームウェアバージョン",
          "examples": ["0.1.0"]
        },
        "firmware_version_max": {
          "type": "string",
          "description": "対応する最大ファームウェアバージョン（省略時は上限なし）",
          "examples": ["2.0.0"]
        },
        "board": {
          "type": "string",
          "description": "想定基板識別子。Kit 作者が調整に使ったハードウェアを示す。デバイスのメタ情報と照合して警告に使用してよい",
          "pattern": "^[a-z][a-z0-9_]*$",
          "examples": ["duo_wl_v3", "neck_wl_v2"]
        },
        "volume_level": {
          "type": "integer",
          "description": "Kit 作者がチューニング時に使ったデバイス音量レベル",
          "minimum": 0
        },
        "volume_wiper": {
          "type": "integer",
          "description": "MCP4018 wiper 値 (0–127)。volume_level より低レベルで再現性が高い",
          "minimum": 0,
          "maximum": 127
        },
        "volume_steps": {
          "type": "integer",
          "description": "デバイスがレポートする音量ステップ総数。Kit 作者環境のコンテキスト",
          "minimum": 1
        }
      }
    },
    "events": {
      "type": "object",
      "description": "Device が flash 焼き込み clip を再生する command-mode event の辞書 (schema 1.x の混合 events 辞書を schema 2.0.0 で command-mode 専用に narrow 化)。キーは PLAY/STOP packet の wire eventId に直接対応する。device kit_loader はこの辞書を読む。",
      "minProperties": 0,
      "patternProperties": {
        "^[a-z][a-z0-9-]{0,63}\\.[a-z][a-z0-9_-]{0,63}$": {
          "type": "object",
          "description": "Event ID に対応する command-mode clip 定義",
          "additionalProperties": false,
          "required": ["clip"],
          "properties": {
            "clip": {
              "type": "string",
              "description": "install-clips/ 配下の相対ファイル名 (bare filename、サブディレクトリ可)。subdir prefix は読む側が自動付与するため JSON 上には書かない。",
              "pattern": "^[^/\\\\].*\\.wav$",
              "examples": ["hit_medium.wav", "ambient/rain_loop.wav"]
            },
            "description": {
              "type": "string",
              "description": "このイベントの説明"
            },
            "tags": {
              "type": "array",
              "description": "分類用タグの配列",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "parameters": {
              "type": "object",
              "description": "再生パラメータ",
              "additionalProperties": false,
              "properties": {
                "intensity": {
                  "type": "number",
                  "description": "制作者が意図した基準強度。WAV フル振幅に対する倍率。SDK gain=1.0 でこの強度で再生される。",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "default": 1.0
                },
                "device_wiper": {
                  "type": "integer",
                  "description": "イベント調整時の Hapbeat デバイスの MCP4018 ワイパー値。再現性のための参照情報。",
                  "minimum": 0,
                  "maximum": 127
                },
                "loop": {
                  "type": "boolean",
                  "description": "ループ再生の有無。デフォルトは false。",
                  "default": false
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "stream_events": {
      "type": "object",
      "description": "SDK がホストから UDP audio stream で送信する event の辞書。device はこのキーを認識しない。同じ eventId が `events` (command) と `stream_events` に並存することは valid (BOTH mode を表す)。",
      "patternProperties": {
        "^[a-z][a-z0-9-]{0,63}\\.[a-z][a-z0-9_-]{0,63}$": {
          "type": "object",
          "description": "Event ID に対応する stream clip 定義",
          "additionalProperties": false,
          "required": ["clip"],
          "properties": {
            "clip": {
              "type": "string",
              "description": "stream-clips/ 配下の相対ファイル名 (bare filename、サブディレクトリ可)。subdir prefix は読む側が自動付与するため JSON 上には書かない。",
              "pattern": "^[^/\\\\].*\\.wav$",
              "examples": ["rain_loop.wav", "ambience/forest.wav"]
            },
            "description": {
              "type": "string",
              "description": "このイベントの説明"
            },
            "tags": {
              "type": "array",
              "description": "分類用タグの配列",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "parameters": {
              "type": "object",
              "description": "再生パラメータ。stream_events では device_wiper は対象外。",
              "additionalProperties": false,
              "properties": {
                "intensity": {
                  "type": "number",
                  "description": "制作者が意図した基準強度。SDK 側 gain への乗算基準値として使われる。",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "default": 1.0
                },
                "loop": {
                  "type": "boolean",
                  "description": "ループ再生の有無。デフォルトは false。",
                  "default": false
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "install_clips": {
      "type": "object",
      "description": "`events` が参照する install-clips/ 配下 WAV のメタデータ辞書。キーは events.<id>.clip と同じ表記。stream-clips/ 配下のファイルは含めない。",
      "additionalProperties": {
        "type": "object",
        "description": "クリップファイルのメタデータ",
        "additionalProperties": false,
        "properties": {
          "duration_ms": {
            "type": "number",
            "description": "クリップの再生時間（ミリ秒）",
            "minimum": 0
          },
          "sample_rate": {
            "type": "number",
            "description": "サンプルレート（Hz）",
            "enum": [8000, 11025, 16000, 22050, 32000, 44100, 48000]
          },
          "channels": {
            "type": "number",
            "description": "チャンネル数",
            "minimum": 1,
            "maximum": 2
          },
          "format": {
            "type": "string",
            "description": "フォーマット識別子",
            "examples": ["pcm_s16le", "pcm_u8"]
          }
        }
      }
    }
  }
}
